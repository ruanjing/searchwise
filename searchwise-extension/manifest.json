{
    "manifest_version": 3,
    "name": "__MSG_appName__",
    "version": "1.2.4",
    "description": "__MSG_appDescription__",
    "default_locale": "en",
    "permissions": [
        "storage",
        "alarms"
    ],
    "host_permissions": [
        "https://www.google.com/*",
        "https://www.google.com.hk/*",
        "https://www.bing.com/*",
        "https://cn.bing.com/*",
        "https://www.baidu.com/*",
        "https://duckduckgo.com/*",
        "https://www.sogou.com/*",
        "https://www.so.com/*",
        "https://so.com/*",
        "https://yandex.com/*",
        "https://yandex.ru/*"
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.google.com/search*",
                "https://www.google.com.hk/search*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/google.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.bing.com/search*",
                "https://cn.bing.com/search*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/bing.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.baidu.com/*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/baidu.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://duckduckgo.com/*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/duckduckgo.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.sogou.com/*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/sogou.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.so.com/*",
                "https://so.com/*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/so360.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://yandex.com/*",
                "https://yandex.ru/*"
            ],
            "js": [
                "content/shared/constants.js",
                "content/shared/i18n.js",
                "content/shared/blacklist-engine.js",
                "content/shared/keyword-highlighter.js",
                "content/shared/usage-tracker.js",
                "content/shared/api-client.js",
                "content/shared/sidebar-injector.js",
                "content/engines/yandex.js",
                "content/main.js"
            ],
            "css": [
                "sidebar/sidebar.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "32": "assets/icons/icon32.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icons/icon16.png",
        "32": "assets/icons/icon32.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "options_page": "options/options.html"
}
